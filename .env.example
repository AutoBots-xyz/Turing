# Backend API base URL.
# Change this for staging/production deployments.
# Default (local dev): http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------
# LLM Layer (via LiteLLM — swap between Claude, GPT-4o, or Ollama)
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default model used by the pipeline (LiteLLM model string).
# Examples: gpt-4o | anthropic/claude-3-5-sonnet | ollama/llama3
DEFAULT_LLM_MODEL=gpt-4o

# Gaussian Process random seed. Unset (default) = None → non-deterministic
# production behaviour. Set to an integer for reproducible local testing.
# GP_RANDOM_STATE=42

# ---------------------------------------------------------------
# Web & Patent Search (Serper.dev — freemium, thousands of free searches)
# Used by: search_web.py, search_patents.py
# Sign up at: https://serper.dev
# ---------------------------------------------------------------
SERPER_API_KEY=your-serper-key-here

# ---------------------------------------------------------------
# Database (SQLite by default — no setup needed for local dev)
# Switch to PostgreSQL for production: postgresql://user:pass@host/db
# ---------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./causal_nexus.db

# ---------------------------------------------------------------
# App Settings
# ---------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# API version exposed by GET / — override in CI/CD on each release
APP_VERSION=1.0.0
# Minimum rows required before a LOW_DATA_WARNING is issued for tabular inputs
MIN_DATA_ROWS=30
# The percentage of the domain search space the Layer 2 Exploiter agent will nudge by
EXPLOITER_NUDGE_PCT=0.01
