# ==============================================================================
# TURING CAUSAL ENGINE - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND / NEXT.JS
# ------------------------------------------------------------------------------
# The URL where the Python backend is running (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# BACKEND / FASTAPI
# ------------------------------------------------------------------------------
# Port for the FastAPI backend (defaults to 8000 if not set)
PORT=8000

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# ------------------------------------------------------------------------------
# LLM Layer (via LiteLLM — swap between Claude, GPT-4o, or Ollama)
# ------------------------------------------------------------------------------
# Default model used by the pipeline (LiteLLM model string).
# Examples: gpt-4o | anthropic/claude-3-5-sonnet | openai/qwen3.6-plus | ollama/llama3
DEFAULT_LLM_MODEL=gpt-4o

# Groq
GROQ_API_KEY=your-groq-key-here

# Aliyun DashScope / OpenAI-compatible key
OPENAI_API_KEY=your-openai-or-dashscope-key-here
OPENAI_API_BASE=https://your-endpoint.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your-dashscope-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NVIDIA NIM (Alternative)
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here

# ------------------------------------------------------------------------------
# SEARCH APIS (Layer 3)
# ------------------------------------------------------------------------------
# Web & Patent Search (Serper.dev — freemium, thousands of free searches)
SERPER_API_KEY=your-serper-key-here

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# Database URL for storing runs and graphs. Uses SQLite locally by default.
# Switch to PostgreSQL for production: postgresql://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./causal_nexus.db

# ------------------------------------------------------------------------------
# ALGORITHM / ENGINE TUNING PARAMETERS (Optional Defaults)
# ------------------------------------------------------------------------------
# Minimum rows required to run Layer 1 PC Algorithm
MIN_DATA_ROWS=30

# Percentage to nudge agent exploitation in Layer 2 (Bayesian optimization)
EXPLOITER_NUDGE_PCT=0.01

# Gaussian Process random seed. Unset (default) = None → non-deterministic
# production behaviour. Set to an integer for reproducible local testing.
GP_RANDOM_STATE=42

# ------------------------------------------------------------------------------
# LAYER 3 SCORING WEIGHTS (Optional Defaults)
# ------------------------------------------------------------------------------
WEIGHT_PATENT=0.70
WEIGHT_PAPER=0.55
WEIGHT_WIKI=0.45
WEIGHT_WEB=0.30

# Citation score multipliers
CITE_500=0.10
CITE_100=0.07
CITE_10=0.03

# Replication multipliers
REP_5=0.05
REP_2=0.02

# Trust multipliers
BOOST_DEPLOYED=0.25
BOOST_REPLICATED=0.15
BOOST_BLOG=-0.10
